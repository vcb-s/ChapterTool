<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:ChapterTool.Avalonia.Views.Controls"
             xmlns:edit="using:AvaloniaEdit"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:transform="clr-namespace:ChapterTool.Core.Transform;assembly=ChapterTool.Core"
             x:Class="ChapterTool.Avalonia.Views.Controls.ExpressionEditor"
             MinHeight="25.6"
             Focusable="True"
             GotFocus="OnWrapperGotFocus"
             PointerPressed="OnPointerPressed">
  <UserControl.Styles>
    <Style Selector="edit|TextEditor">
      <Setter Property="FontFamily" Value="{DynamicResource ChapterTool.MonospaceFontFamily}" />
    </Style>
  </UserControl.Styles>
  <UserControl.Resources>
    <controls:ExpressionCompletionKindBrushConverter x:Key="CompletionKindBrushConverter" />
  </UserControl.Resources>
  <Grid x:Name="RootGrid"
        ClipToBounds="False">
    <Border x:Name="EditorBorder"
            Background="{DynamicResource ChapterTool.ControlBackgroundBrush}"
            BorderBrush="{DynamicResource ChapterTool.BorderBrush}"
            BorderThickness="1"
            CornerRadius="2">
      <ContentControl x:Name="EditorHost" />
    </Border>

    <Button x:Name="MultilineToggleButton"
            Width="24"
            Height="20"
            MinWidth="24"
            Padding="0"
            Margin="0,2,2,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            IsVisible="False"
            Click="OnMultilineToggleClick">
      <Grid>
        <i:Icon x:Name="MultilineExpandIcon" Value="fa-solid fa-chevron-down" FontSize="11" />
        <i:Icon x:Name="MultilineCollapseIcon" Value="fa-solid fa-chevron-up" FontSize="11" IsVisible="False" />
      </Grid>
    </Button>

    <Popup x:Name="CompletionPopup"
           Placement="AnchorAndGravity"
           PlacementAnchor="TopLeft"
           PlacementGravity="BottomLeft"
           PlacementConstraintAdjustment="None"
           IsLightDismissEnabled="False">
      <Border x:Name="CompletionPanel"
              MinWidth="300"
              MaxWidth="520"
              MaxHeight="260"
              Background="{DynamicResource ChapterTool.ControlBackgroundBrush}"
              BorderBrush="{DynamicResource ChapterTool.BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              BoxShadow="0 6 18 0 #22000000">
        <ListBox x:Name="CompletionList"
                 Background="Transparent"
                 BorderThickness="0"
                 Focusable="False"
                 PointerPressed="OnCompletionListPointerPressed"
                 SelectionChanged="OnCompletionSelectionChanged"
                 DoubleTapped="OnCompletionListDoubleTapped">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Focusable" Value="False" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="transform:ExpressionCompletion">
              <Grid ColumnDefinitions="22,210,*,56" Margin="8,5" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="{Binding Kind, Converter={StaticResource CompletionKindBrushConverter}, ConverterParameter=icon}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{Binding Kind, Converter={StaticResource CompletionKindBrushConverter}}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Text}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Description}"
                           Opacity="0.72"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="3"
                           Text="{Binding KindLabel}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Opacity="0.68"
                           Foreground="{Binding Kind, Converter={StaticResource CompletionKindBrushConverter}}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Popup>

    <Popup x:Name="DiagnosticPopup"
           Placement="BottomEdgeAlignedLeft"
           IsLightDismissEnabled="False">
      <Border x:Name="DiagnosticPanel"
              MaxWidth="360"
              Background="{DynamicResource ChapterTool.ControlBackgroundBrush}"
              BorderBrush="{DynamicResource ChapterTool.DiagnosticErrorBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="10,8"
              BoxShadow="0 6 18 0 #22000000"
              PointerEntered="OnDiagnosticPanelPointerEntered"
              PointerExited="OnDiagnosticPanelPointerExited">
        <TextBlock x:Name="DiagnosticTextBlock"
                   Foreground="{DynamicResource ChapterTool.DiagnosticErrorBrush}"
                   TextWrapping="Wrap" />
      </Border>
    </Popup>
  </Grid>
</UserControl>
