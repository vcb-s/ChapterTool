<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:vm="using:ChapterTool.Avalonia.ViewModels"
        xmlns:models="using:ChapterTool.Core.Models"
        x:Class="ChapterTool.Avalonia.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{DynamicResource App.Title}"
        Width="920"
        Height="720"
        MinWidth="760"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ChapterTool.BackChangeBrush}"
        Opened="OnOpened"
        KeyDown="OnKeyDown"
        SizeChanged="OnSizeChanged"
        DragDrop.AllowDrop="True"
        DragDrop.Drop="OnDrop"
        x:CompileBindings="True">
  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.primaryAction">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.TextBackBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="FontSize" Value="17" />
      <Setter Property="MinWidth" Value="118" />
      <Setter Property="MinHeight" Value="54" />
    </Style>
    <Style Selector="Button.iconAction">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.TextBackBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="44" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.statusAction">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.TextBackBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinWidth" Value="52" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="10,2" />
    </Style>
    <Style Selector="ComboBox, TextBox, NumericUpDown">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.TextBackBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.optionLabel">
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Grid.optionCell">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.BackChangeBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="GridLinesVisibility" Value="All" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="RowHeight" Value="30" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.TextBackBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,1,1" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.TextBackBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.TextFrontBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,1,1" />
      <Setter Property="Padding" Value="8,2" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.MouseOverBrush}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource ChapterTool.MouseDownBrush}" />
    </Style>
  </Window.Styles>

  <DockPanel x:Name="RootPanel" LastChildFill="True">
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource ChapterTool.BackChangeBrush}"
            BorderBrush="{DynamicResource ChapterTool.BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto" Height="34">
        <TextBlock x:Name="StatusBlock"
                   Grid.Column="0"
                   Margin="10,0"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Foreground="{DynamicResource ChapterTool.TextFrontBrush}"
                   Text="{Binding StatusText}" />
        <ProgressBar x:Name="ProgressBar"
                     Grid.Column="2"
                     Width="180"
                     Height="10"
                     Margin="12,0,16,0"
                     VerticalAlignment="Center"
                     Minimum="0"
                     Maximum="1"
                     Value="{Binding Progress}"
                     AutomationProperties.AutomationId="ProgressBar" />
        <Button x:Name="LogButton"
                Grid.Column="1"
                Classes="statusAction"
                VerticalAlignment="Center"
                AutomationProperties.AutomationId="LogWindow"
                Content="{DynamicResource Main.Log}"
                Command="{Binding LogCommand}" />
      </Grid>
    </Border>

    <Grid Margin="18"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="14">
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
          <Button x:Name="LoadButton"
                  Classes="primaryAction"
                  AutomationProperties.AutomationId="LoadButton"
                  Content="{DynamicResource Main.Load}"
                  Command="{Binding #RootWindow.BrowseAndLoadCommand}">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem x:Name="ReloadMenuItem" Header="{DynamicResource Main.Reload}" Command="{Binding #RootWindow.ReloadCommand}" />
                <MenuItem x:Name="AppendLoadMenuItem" Header="{DynamicResource Main.AppendMpls}" IsEnabled="{Binding CanAppendMpls}" Command="{Binding #RootWindow.AppendMplsCommand}" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
          <Button x:Name="SaveButton"
                  Classes="primaryAction"
                  AutomationProperties.AutomationId="SaveButton"
                  Content="{DynamicResource Common.Save}"
                  IsEnabled="{Binding CanSave}"
                  Command="{Binding #RootWindow.SaveCommand}">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem x:Name="SaveToMenuItem" Header="{DynamicResource Main.SaveTo}" Command="{Binding #RootWindow.SaveToCommand}" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
        </StackPanel>

        <ComboBox x:Name="ClipBox"
                  Grid.Column="1"
                  MinWidth="220"
                  MaxWidth="360"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  ItemsSource="{Binding ClipOptions}"
                  SelectedIndex="{Binding SelectedClipIndex, Mode=OneWay}"
                  IsVisible="{Binding IsClipSelectionVisible}"
                  SelectionChanged="OnClipSelectionChanged"
                  AutomationProperties.AutomationId="ClipSelector">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="models:ChapterSourceOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
          <ComboBox.SelectionBoxItemTemplate>
            <DataTemplate x:DataType="models:ChapterSourceOption">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.SelectionBoxItemTemplate>
          <ComboBox.ContextMenu>
            <ContextMenu>
              <MenuItem x:Name="ClipCombineMenuItem" Header="{DynamicResource Main.Combine}" IsEnabled="{Binding CanCombine}" Command="{Binding #RootWindow.CombineCommand}" />
            </ContextMenu>
          </ComboBox.ContextMenu>
        </ComboBox>

        <Grid Grid.Column="2"
              RowDefinitions="Auto,Auto"
              RowSpacing="8"
              HorizontalAlignment="Right"
              MinWidth="260">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <CheckBox x:Name="RoundFramesBox"
                      Content="{DynamicResource Main.RoundFrames}"
                      IsChecked="{Binding RoundFrames}"
                      IsCheckedChanged="OnFrameOptionsChanged" />
            <Button x:Name="PreviewButton"
                    Classes="iconAction"
                    AutomationProperties.AutomationId="PreviewWindow"
                    Command="{Binding #RootWindow.PreviewCommand}"
                    ToolTip.Tip="{DynamicResource Main.Preview}">
              <i:Icon Value="fa-solid fa-eye" FontSize="17" />
            </Button>
            <Button x:Name="RefreshButton"
                    Classes="iconAction"
                    AutomationProperties.AutomationId="RefreshRows"
                    IsEnabled="{Binding CanRefreshRows}"
                    Command="{Binding #RootWindow.RefreshRowsCommand}"
                    ToolTip.Tip="{DynamicResource Common.Refresh}">
              <i:Icon Value="fa-solid fa-rotate" FontSize="17" />
            </Button>
            <Button x:Name="SettingsButton"
                    Classes="iconAction"
                    AutomationProperties.AutomationId="SettingsWindow"
                    Command="{Binding SettingsCommand}"
                    ToolTip.Tip="{DynamicResource Main.SettingsShort}">
              <i:Icon Value="fa-solid fa-gear" FontSize="17" />
            </Button>
          </StackPanel>
          <ComboBox x:Name="FrameRateBox"
                    Grid.Row="1"
                    Width="190"
                    HorizontalAlignment="Right"
                    SelectedIndex="{Binding SelectedFrameRateIndex}"
                    SelectionChanged="OnFrameOptionsChanged">
            <ComboBox.ContextMenu>
              <ContextMenu>
                <MenuItem Header="ChangeFps" Command="{Binding ChangeFpsCommand}" />
              </ContextMenu>
            </ComboBox.ContextMenu>
            <ComboBoxItem Content="{DynamicResource Main.AutoFrameRate}" />
            <ComboBoxItem Content="24000 / 1001" />
            <ComboBoxItem Content="24000 / 1000" />
            <ComboBoxItem Content="25000 / 1000" />
            <ComboBoxItem Content="30000 / 1001" />
            <ComboBoxItem Content="RESER / VED" />
            <ComboBoxItem Content="50000 / 1000" />
            <ComboBoxItem Content="60000 / 1001" />
          </ComboBox>
        </Grid>
      </Grid>

      <Grid Grid.Row="1" RowDefinitions="Auto,*" MinHeight="0">
        <TextBox x:Name="PathBox"
                 Grid.Row="0"
                 IsVisible="False"
                 AutomationProperties.AutomationId="SourcePath" />
        <DataGrid x:Name="ChapterGrid"
                  Grid.Row="1"
                  MinHeight="260"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  SelectionMode="Extended"
                  ItemsSource="{Binding Rows}"
                  CellEditEnded="OnChapterGridCellEditEnded"
                  AutomationProperties.AutomationId="ChapterGrid">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem x:Name="InsertMenuItem" Header="{DynamicResource Main.Insert}" IsEnabled="{Binding CanEditRows}" Command="{Binding #RootWindow.InsertSelectedCommand}" />
              <MenuItem x:Name="DeleteMenuItem" Header="{DynamicResource Main.Delete}" IsEnabled="{Binding CanEditRows}" Command="{Binding #RootWindow.DeleteSelectedCommand}" />
              <MenuItem x:Name="GridCombineMenuItem" Header="{DynamicResource Main.Combine}" IsEnabled="{Binding CanCombine}" Command="{Binding #RootWindow.CombineCommand}" />
              <MenuItem x:Name="OpenMediaMenuItem" Header="{DynamicResource Main.OpenRelatedMedia}" IsEnabled="{Binding CanOpenRelatedMedia}" Command="{Binding #RootWindow.OpenRelatedMediaCommand}" />
              <MenuItem x:Name="ZonesMenuItem" Header="{DynamicResource Main.CreateZones}" Command="{Binding #RootWindow.OpenZonesCommand}" />
              <MenuItem x:Name="ForwardShiftMenuItem" Header="{DynamicResource Main.ForwardTranslation}" Command="{Binding #RootWindow.OpenForwardShiftCommand}" />
              <MenuItem x:Name="PreviewMenuItem" Header="{DynamicResource Main.Preview}" Command="{Binding #RootWindow.PreviewCommand}" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTextColumn Header="#" Binding="{Binding Number}" IsReadOnly="True" Width="64" MinWidth="56" />
            <DataGridTextColumn Header="{DynamicResource Main.ColumnTime}" Binding="{Binding TimeText}" Width="170" MinWidth="132" />
            <DataGridTextColumn Header="{DynamicResource Main.ColumnName}" Binding="{Binding Name}" Width="*" MinWidth="180" />
            <DataGridTextColumn Header="{DynamicResource Main.ColumnFrames}" Binding="{Binding FramesInfo}" Width="150" MinWidth="96" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>

      <Grid x:Name="AdvancedOptionsGrid"
            Grid.Row="2"
            ColumnDefinitions="*,2*,*"
            RowDefinitions="Auto,Auto"
            ColumnSpacing="18"
            RowSpacing="10"
            Margin="0"
            AutomationProperties.AutomationId="AdvancedOptions">
        <Grid x:Name="FormatOptionsGroup"
              Classes="optionCell"
              Grid.Row="0"
              Grid.Column="0"
              ColumnDefinitions="72,*"
              ColumnSpacing="8">
          <TextBlock Grid.Column="0" Classes="optionLabel" HorizontalAlignment="Right" Text="{DynamicResource Main.SaveFormat}" />
          <ComboBox x:Name="FormatBox"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="{Binding SaveFormatIndex}"
                    AutomationProperties.AutomationId="ExportFormat">
            <ComboBoxItem Content="TXT" />
            <ComboBoxItem Content="XML" />
            <ComboBoxItem Content="QPF" />
            <ComboBoxItem Content="TimeCodes" />
            <ComboBoxItem Content="TsmuxerMeta" />
            <ComboBoxItem Content="CUE" />
            <ComboBoxItem Content="JSON" />
            <ComboBoxItem Content="WebVTT" />
            <ComboBoxItem Content="Celltimes" />
            <ComboBoxItem Content="Chapter2Qpfile" />
          </ComboBox>
        </Grid>

        <Grid x:Name="ChapterNameOptionsGroup"
              Classes="optionCell"
              Grid.Row="0"
              Grid.Column="1"
              ColumnDefinitions="84,*,Auto"
              ColumnSpacing="8">
          <TextBlock Grid.Column="0" Classes="optionLabel" HorizontalAlignment="Right" Text="{DynamicResource Main.ChapterName}" />
          <ComboBox x:Name="ChapterNameModeBox"
                    Grid.Column="1"
                    MinWidth="120"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="{Binding ChapterNameModeIndex}"
                    AutomationProperties.AutomationId="ChapterNameMode">
            <ComboBoxItem Content="{DynamicResource Main.KeepOriginalName}" />
            <ComboBoxItem Content="{DynamicResource Main.StandardTemplate}" />
            <ComboBoxItem Content="{DynamicResource Main.TemplateFile}" />
          </ComboBox>
          <Button x:Name="ChapterNameTemplateButton"
                  Grid.Column="2"
                  MinWidth="44"
                  MinHeight="32"
                  Padding="8,4"
                  AutomationProperties.AutomationId="ChapterNameTemplateFile"
                  Command="{Binding #RootWindow.LoadChapterNameTemplateCommand}"
                  ToolTip.Tip="{DynamicResource Main.TemplateFile}">
            <i:Icon Value="fa-solid fa-folder-open" FontSize="14" />
          </Button>
        </Grid>

        <Grid x:Name="OrderShiftOptionsGroup"
              Classes="optionCell"
              Grid.Row="1"
              Grid.Column="1"
              ColumnDefinitions="84,*"
              ColumnSpacing="8">
          <TextBlock Grid.Column="0" Classes="optionLabel" HorizontalAlignment="Right" Text="{DynamicResource Main.OrderShift}" />
          <NumericUpDown x:Name="OrderShiftBox"
                         Grid.Column="1"
                         MinWidth="92"
                         HorizontalAlignment="Stretch"
                         Minimum="-1000"
                         Maximum="1000"
                         Increment="1"
                         Value="{Binding OrderShift}"
                         ValueChanged="OnOrderShiftValueChanged"
                         AutomationProperties.AutomationId="OrderShift" />
        </Grid>

        <Grid x:Name="XmlLanguageOptionsGroup"
              Classes="optionCell"
              Grid.Row="1"
              Grid.Column="0"
              ColumnDefinitions="72,*"
              ColumnSpacing="8"
              IsEnabled="{Binding IsXmlLanguageEnabled}"
              HorizontalAlignment="Stretch">
          <TextBlock Grid.Column="0" Classes="optionLabel" HorizontalAlignment="Right" Text="{DynamicResource Main.XmlLanguage}" />
          <ComboBox x:Name="XmlLanguageBox"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding XmlLanguageOptions}"
                    SelectedIndex="{Binding XmlLanguageIndex}"
                    AutomationProperties.AutomationId="XmlLanguage" />
        </Grid>

        <Grid x:Name="ExpressionOptionsGroup"
              Classes="optionCell"
              Grid.Row="2"
              Grid.Column="0"
              ColumnDefinitions="84,88,*"
              ColumnSpacing="8">
          <TextBlock Grid.Column="0" Classes="optionLabel" HorizontalAlignment="Right" Text="{DynamicResource Main.Expression}" />
          <CheckBox x:Name="ApplyExpressionBox"
                    Grid.Column="1"
                    AutomationProperties.AutomationId="ApplyExpression"
                    IsChecked="{Binding ApplyExpression}"
                    Content="{DynamicResource Common.Use}" />
          <TextBox x:Name="ExpressionBox"
                   Grid.Column="2"
                   MinWidth="120"
                   HorizontalAlignment="Stretch"
                   Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                   AutomationProperties.AutomationId="ExpressionText" />
        </Grid>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
