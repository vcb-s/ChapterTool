<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:vm="using:ChapterTool.Avalonia.ViewModels"
             x:Class="ChapterTool.Avalonia.Views.Tools.SettingsToolView"
             x:DataType="vm:SettingsToolViewModel"
             x:CompileBindings="True">
  <UserControl.Styles>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="TextBlock.tabHeader">
      <Setter Property="TextWrapping" Value="NoWrap" />
      <Setter Property="Margin" Value="2,0" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.status">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.MutedForegroundBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.aboutBody">
      <Setter Property="MaxWidth" Value="680" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="22" />
    </Style>
    <Style Selector="TextBlock.repoAddress">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="FontFamily" Value="{DynamicResource ChapterTool.MonospaceFontFamily}" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.AccentBrush}" />
    </Style>
    <Style Selector="Button.linkButton">
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource ChapterTool.AccentBrush}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="TextBox, ComboBox">
      <Setter Property="MinHeight" Value="32" />
    </Style>
    <Style Selector="Slider.toleranceSlider">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox.outputDefaultCombo">
      <Setter Property="Width" Value="180" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="TextBlock.valueBadge">
      <Setter Property="MinWidth" Value="46" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Right" />
    </Style>
    <Style Selector="Border.themeSwatch">
      <Setter Property="Width" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Margin" Value="0,0,4,4" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.fontPreview">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="MaxWidth" Value="440" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="{DynamicResource ChapterTool.ControlBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ChapterTool.BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.compact">
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="8,3" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto" Margin="16" RowSpacing="12">
    <TabControl Grid.Row="0">
      <TabItem>
        <TabItem.Header>
          <TextBlock Classes="tabHeader" Text="{DynamicResource Settings.General}" />
        </TabItem.Header>
        <ScrollViewer Classes="settingsPageScroller" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12" Margin="4,12,12,4">
            <TextBlock Classes="sectionTitle" Text="{DynamicResource Settings.General}" />
            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="12">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.UiLanguage}" />
              <ComboBox Grid.Row="0"
                        Grid.Column="1"
                        ItemsSource="{Binding Languages}"
                        SelectedIndex="{Binding SelectedLanguageIndex}">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="vm:LanguageOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.SaveDirectory}" />
              <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                <TextBox Grid.Column="0" Text="{Binding SaveDirectory, Mode=TwoWay}" PlaceholderText="{DynamicResource Settings.EmptyUsesSource}" />
                <Button Grid.Column="1" Classes="compact" Command="{Binding BrowseSaveDirectoryCommand}" AutomationProperties.Name="{DynamicResource Settings.BrowseDirectory}" ToolTip.Tip="{DynamicResource Settings.BrowseDirectory}">
                  <i:Icon Value="fa-solid fa-folder-open" FontSize="14" />
                </Button>
                <Button Grid.Column="2" Classes="compact" Command="{Binding ClearSaveDirectoryCommand}" AutomationProperties.Name="{DynamicResource Common.Clear}" ToolTip.Tip="{DynamicResource Common.Clear}">
                  <i:Icon Value="fa-solid fa-xmark" FontSize="14" />
                </Button>
              </Grid>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem>
        <TabItem.Header>
          <TextBlock Classes="tabHeader" Text="{DynamicResource Settings.ExternalTools}" />
        </TabItem.Header>
        <ScrollViewer Classes="settingsPageScroller" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12" Margin="4,12,12,4">
            <TextBlock Classes="sectionTitle" Text="{DynamicResource Settings.ExternalTools}" />
            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.MkvToolnixPath}" />
              <Grid Grid.Row="0" Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <TextBox Grid.Column="0" Text="{Binding MkvToolnixPath, Mode=TwoWay}" />
                  <Button Grid.Column="1" Classes="compact" Command="{Binding BrowseMkvToolnixCommand}" AutomationProperties.Name="{DynamicResource Settings.BrowseExecutable}" ToolTip.Tip="{DynamicResource Settings.BrowseExecutable}">
                    <i:Icon Value="fa-solid fa-folder-open" FontSize="14" />
                  </Button>
                  <Button Grid.Column="2" Classes="compact" Command="{Binding ClearMkvToolnixCommand}" AutomationProperties.Name="{DynamicResource Common.Clear}" ToolTip.Tip="{DynamicResource Common.Clear}">
                    <i:Icon Value="fa-solid fa-xmark" FontSize="14" />
                  </Button>
                </Grid>
                <TextBlock Grid.Row="1" Classes="status" Text="{Binding MkvToolnixStatus}" />
              </Grid>

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.Eac3toPath}" />
              <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <TextBox Grid.Column="0" Text="{Binding Eac3toPath, Mode=TwoWay}" />
                  <Button Grid.Column="1" Classes="compact" Command="{Binding BrowseEac3toCommand}" AutomationProperties.Name="{DynamicResource Settings.BrowseExecutable}" ToolTip.Tip="{DynamicResource Settings.BrowseExecutable}">
                    <i:Icon Value="fa-solid fa-folder-open" FontSize="14" />
                  </Button>
                  <Button Grid.Column="2" Classes="compact" Command="{Binding ClearEac3toCommand}" AutomationProperties.Name="{DynamicResource Common.Clear}" ToolTip.Tip="{DynamicResource Common.Clear}">
                    <i:Icon Value="fa-solid fa-xmark" FontSize="14" />
                  </Button>
                </Grid>
                <TextBlock Grid.Row="1" Classes="status" Text="{Binding Eac3toStatus}" />
              </Grid>

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.FfprobePath}" />
              <Grid Grid.Row="2" Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <TextBox Grid.Column="0" Text="{Binding FfprobePath, Mode=TwoWay}" />
                  <Button Grid.Column="1" Classes="compact" Command="{Binding BrowseFfprobeCommand}" AutomationProperties.Name="{DynamicResource Settings.BrowseExecutable}" ToolTip.Tip="{DynamicResource Settings.BrowseExecutable}">
                    <i:Icon Value="fa-solid fa-folder-open" FontSize="14" />
                  </Button>
                  <Button Grid.Column="2" Classes="compact" Command="{Binding ClearFfprobeCommand}" AutomationProperties.Name="{DynamicResource Common.Clear}" ToolTip.Tip="{DynamicResource Common.Clear}">
                    <i:Icon Value="fa-solid fa-xmark" FontSize="14" />
                  </Button>
                </Grid>
                <TextBlock Grid.Row="1" Classes="status" Text="{Binding FfprobeStatus}" />
              </Grid>

              <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.FfmpegPath}" />
              <Grid Grid.Row="3" Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="3">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <TextBox Grid.Column="0" Text="{Binding FfmpegPath, Mode=TwoWay}" />
                  <Button Grid.Column="1" Classes="compact" Command="{Binding BrowseFfmpegCommand}" AutomationProperties.Name="{DynamicResource Settings.BrowseDirectory}" ToolTip.Tip="{DynamicResource Settings.BrowseDirectory}">
                    <i:Icon Value="fa-solid fa-folder-open" FontSize="14" />
                  </Button>
                  <Button Grid.Column="2" Classes="compact" Command="{Binding ClearFfmpegCommand}" AutomationProperties.Name="{DynamicResource Common.Clear}" ToolTip.Tip="{DynamicResource Common.Clear}">
                    <i:Icon Value="fa-solid fa-xmark" FontSize="14" />
                  </Button>
                </Grid>
                <TextBlock Grid.Row="1" Classes="status" Text="{Binding FfmpegStatus}" />
              </Grid>
            </Grid>
            <Button HorizontalAlignment="Left" Command="{Binding ValidateToolsCommand}" ToolTip.Tip="{DynamicResource Settings.ValidateTools}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <i:Icon Value="fa-solid fa-magnifying-glass" FontSize="14" />
                <TextBlock Text="{DynamicResource Settings.ValidateTools}" />
              </StackPanel>
            </Button>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem>
        <TabItem.Header>
          <TextBlock Classes="tabHeader" Text="{DynamicResource Settings.OutputDefaults}" />
        </TabItem.Header>
        <ScrollViewer Classes="settingsPageScroller" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" Margin="4,12,12,4">
          <TextBlock Classes="sectionTitle" Text="{DynamicResource Settings.OutputDefaults}" />
          <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
            <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.DefaultSaveFormat}" />
            <ComboBox x:Name="DefaultSaveFormatCombo"
                      Grid.Row="0"
                      Grid.Column="1"
                      Classes="outputDefaultCombo"
                      ItemsSource="{Binding SaveFormatOptions}"
                      SelectedIndex="{Binding DefaultSaveFormatIndex}" />
            <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.DefaultXmlLanguage}" />
            <ComboBox x:Name="DefaultXmlLanguageCombo"
                      Grid.Row="1"
                      Grid.Column="1"
                      Classes="outputDefaultCombo"
                      ItemsSource="{Binding XmlLanguageDisplayOptions}"
                      SelectedItem="{Binding SelectedDefaultXmlLanguageDisplayOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:SelectorDisplayOption">
                  <TextBlock VerticalAlignment="Center" Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
              <ComboBox.SelectionBoxItemTemplate>
                <DataTemplate x:DataType="vm:SelectorDisplayOption">
                  <TextBlock VerticalAlignment="Center" Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" />
                </DataTemplate>
              </ComboBox.SelectionBoxItemTemplate>
            </ComboBox>
            <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.EmitBom}" />
            <CheckBox Grid.Row="2"
                      Grid.Column="1"
                      IsChecked="{Binding EmitBom}"
                      VerticalAlignment="Center" />
            <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.FrameAccuracyTolerance}" />
            <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <Slider Grid.Column="0"
                      Classes="toleranceSlider"
                      Minimum="0.01"
                      Maximum="0.30"
                      Ticks="0.05,0.10,0.15,0.20,0.25,0.30"
                      TickPlacement="BottomRight"
                      IsSnapToTickEnabled="False"
                      Value="{Binding FrameAccuracyToleranceSliderValue}" />
              <TextBlock Grid.Column="1"
                         Classes="valueBadge"
                         Text="{Binding FrameAccuracyToleranceDisplayText}" />
            </Grid>
          </Grid>
        </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem>
        <TabItem.Header>
          <TextBlock Classes="tabHeader" Text="{DynamicResource Settings.Appearance}" />
        </TabItem.Header>
        <ScrollViewer Classes="settingsPageScroller" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="12" Margin="4,12,12,4">
            <TextBlock Classes="sectionTitle" Text="{DynamicResource Settings.Appearance}" />
            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.Appearance.Preset}" />
              <ComboBox x:Name="ThemePresetCombo"
                        Grid.Row="0"
                        Grid.Column="1"
                        MinWidth="240"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding ThemePresets}"
                        SelectedIndex="{Binding SelectedThemePresetIndex}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ThemePresetOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.SelectionBoxItemTemplate>
                  <DataTemplate x:DataType="vm:ThemePresetOptionViewModel">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.SelectionBoxItemTemplate>
              </ComboBox>
              <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.Appearance.Preview}" />
              <ItemsControl x:Name="ThemePalettePreview"
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding SelectedThemePreset.PreviewSwatches}"
                            AutomationProperties.Name="{Binding ThemePreviewAutomationName}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ThemeSwatchViewModel">
                    <Border Classes="themeSwatch" Background="{Binding Color}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.Appearance.UiFont}" />
              <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6" MaxWidth="440" HorizontalAlignment="Left">
                <ComboBox x:Name="UiFontFamilyCombo"
                          MinWidth="240"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding UiFontFamilies}"
                          SelectedIndex="{Binding SelectedUiFontFamilyIndex}">
                  <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ComboBox.ItemsPanel>
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FontFamilyOptionViewModel">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontFamily="{Binding PreviewFontFamily}"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                  <ComboBox.SelectionBoxItemTemplate>
                    <DataTemplate x:DataType="vm:FontFamilyOptionViewModel">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontFamily="{Binding PreviewFontFamily}"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.SelectionBoxItemTemplate>
                </ComboBox>
                <Border x:Name="UiFontPreview"
                        Classes="fontPreview"
                        AutomationProperties.Name="{Binding UiFontPreviewAutomationName}">
                  <TextBlock FontFamily="{DynamicResource ChapterTool.UiFontFamily}"
                             Text="{Binding FontPreviewText}"
                             TextTrimming="CharacterEllipsis" />
                </Border>
              </StackPanel>

              <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="{DynamicResource Settings.Appearance.MonospaceFont}" />
              <StackPanel Grid.Row="3" Grid.Column="1" Spacing="6" MaxWidth="440" HorizontalAlignment="Left">
                <ComboBox x:Name="MonospaceFontFamilyCombo"
                          MinWidth="240"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding MonospaceFontFamilies}"
                          SelectedIndex="{Binding SelectedMonospaceFontFamilyIndex}">
                  <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ComboBox.ItemsPanel>
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FontFamilyOptionViewModel">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontFamily="{Binding PreviewFontFamily}"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                  <ComboBox.SelectionBoxItemTemplate>
                    <DataTemplate x:DataType="vm:FontFamilyOptionViewModel">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontFamily="{Binding PreviewFontFamily}"
                                 TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ComboBox.SelectionBoxItemTemplate>
                </ComboBox>
                <Border x:Name="MonospaceFontPreview"
                        Classes="fontPreview"
                        AutomationProperties.Name="{Binding MonospaceFontPreviewAutomationName}">
                  <TextBlock FontFamily="{DynamicResource ChapterTool.MonospaceFontFamily}"
                             Text="{Binding FontPreviewText}"
                             TextTrimming="CharacterEllipsis" />
                </Border>
              </StackPanel>
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem>
        <TabItem.Header>
          <TextBlock Classes="tabHeader" Text="{DynamicResource Settings.About}" />
        </TabItem.Header>
        <ScrollViewer Classes="settingsPageScroller" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="14" Margin="4,12,12,4">
            <TextBlock Classes="aboutBody" Text="{DynamicResource Settings.About.Description}" />
            <StackPanel Spacing="4">
              <TextBlock Classes="status" Text="{Binding AvaloniaRuntimeDisplay}" />
              <TextBlock Classes="status" Text="{Binding DotNetRuntimeDisplay}" />
            </StackPanel>
            <TextBlock Classes="status" Text="{DynamicResource Settings.About.License}" />
            <Button Classes="linkButton"
                    Command="{Binding OpenRepositoryCommand}"
                    ToolTip.Tip="{DynamicResource Settings.About.OpenRepository}">
              <TextBlock Classes="repoAddress" Text="{DynamicResource Settings.About.RepositoryUrl}" />
            </Button>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

    </TabControl>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
      <TextBlock Grid.Column="0" Classes="status" VerticalAlignment="Center" Text="{Binding StatusText}" />
      <Button Grid.Column="1" Content="{DynamicResource Settings.ResetDefaults}" Command="{Binding ResetCommand}" />
      <Button Grid.Column="2" Content="{DynamicResource Common.Save}" Command="{Binding SaveCommand}" />
    </Grid>
  </Grid>
</UserControl>
