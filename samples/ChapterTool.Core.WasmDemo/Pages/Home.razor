@page "/"
@implements IDisposable
@inject DemoWorkspace Workspace
@inject IJSRuntime Js

<PageTitle>ChapterTool</PageTitle>

<div class="shell"
     @ondragover:preventDefault
     @ondrop="OnDropAsync"
     @ondrop:preventDefault>
    <div class="main">
        <!-- Top: load/save + clip + frame tools (Avalonia zone) -->
        <div class="top-bar">
            <div class="top-actions">
                <button type="button"
                        class="primary"
                        disabled="@Workspace.IsBusy"
                        @onclick="TriggerLoad"
                        title="Load chapter file">
                    Load
                </button>
                <button type="button"
                        class="primary"
                        disabled="@(!Workspace.CanSave)"
                        @onclick="SaveAsync"
                        title="Export with current options and download">
                    Save
                </button>
                <button type="button"
                        class="primary"
                        disabled="@(!Workspace.CanSave)"
                        @onclick="SaveAsync"
                        title="Save As (download)">
                    Save As
                </button>
                <InputFile id="loadFileInput"
                           class="hidden-file"
                           OnChange="OnFileSelected"
                           accept=".txt,.vtt,.xml,.cue,.mpls,.ifo,.csv,text/*,application/xml" />
            </div>

            <div class="top-clip">
                @if (Workspace.IsClipSelectionVisible)
                {
                    <select class="clip-box"
                            value="@Workspace.SelectedClipId"
                            disabled="@Workspace.IsBusy"
                            @onchange="OnClipChanged"
                            title="Clip / playlist entry">
                        @foreach (var clip in Workspace.ClipOptions)
                        {
                            <option value="@clip.Id">@clip.DisplayText</option>
                        }
                    </select>
                }
            </div>

            <div class="top-tools">
                <label class="check">
                    <input type="checkbox"
                           checked="@roundFrames"
                           disabled="@(Workspace.IsBusy || Workspace.IsChapterGridEmpty)"
                           @onchange="OnRoundFramesChanged" />
                    Round frames
                </label>
                <select class="fps-box"
                        value="@selectedFrameRateIndex"
                        disabled="@(Workspace.IsBusy || Workspace.IsChapterGridEmpty)"
                        @onchange="OnFrameRateChanged"
                        title="Frame rate used for Frames column">
                    @if (Workspace.FrameRateChoices.Count == 0)
                    {
                        <option value="0">—</option>
                    }
                    else
                    {
                        @foreach (var choice in Workspace.FrameRateChoices)
                        {
                            <option value="@choice.Index">@choice.DisplayName</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Center: chapter grid -->
        <div class="grid-zone">
            @if (!string.IsNullOrEmpty(Workspace.SourcePath))
            {
                <div class="path-line" title="@Workspace.SourcePath">
                    @Workspace.SourcePath
                    @if (Workspace.FramesPerSecond > 0)
                    {
                        <span class="path-fps"> · @Workspace.FramesPerSecondDisplay fps</span>
                    }
                </div>
            }

            <div class="grid-wrap">
                @if (Workspace.IsChapterGridEmpty)
                {
                    <div class="empty-state">
                        <div class="empty-icon">∅</div>
                        <p>No chapters loaded</p>
                        <p class="hint">Load a file or load the sample to compute frames and expressions.</p>
                        <button type="button" class="secondary" disabled="@Workspace.IsBusy" @onclick="LoadSampleAsync">
                            Load OGM sample
                        </button>
                    </div>
                }
                else
                {
                    <table class="chapter-grid">
                        <thead>
                        <tr>
                            <th class="col-num">#</th>
                            <th class="col-time">Time</th>
                            <th class="col-name">Name</th>
                            <th class="col-frames">Frames</th>
                        </tr>
                        </thead>
                        <tbody>
                        @for (var i = 0; i < Workspace.Rows.Count; i++)
                        {
                            var index = i;
                            var row = Workspace.Rows[i];
                            <tr class="@(row.IsSeparator ? "separator" : null)">
                                <td class="col-num">@(row.IsSeparator ? "—" : row.Number.ToString())</td>
                                <td class="col-time">
                                    @if (row.IsSeparator)
                                    {
                                        <span></span>
                                    }
                                    else
                                    {
                                        <input class="cell-edit"
                                               value="@row.TimeText"
                                               disabled="@Workspace.IsBusy"
                                               @onchange="e => OnTimeChanged(index, e)" />
                                    }
                                </td>
                                <td class="col-name">
                                    <input class="cell-edit"
                                           value="@row.Name"
                                           disabled="@Workspace.IsBusy"
                                           @onchange="e => OnNameChanged(index, e)" />
                                </td>
                                <td class="col-frames">
                                    <span class="frame-text @(row.IsFrameAccurate ? "accurate" : row.IsFrameInexact ? "inexact" : "neutral")">
                                        @(string.IsNullOrEmpty(row.FramesInfo) ? "—" : row.FramesInfo)
                                    </span>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        <!-- Bottom: export / projection options (Avalonia zone) -->
        <div class="options-zone">
            <div class="option-cell">
                <label class="option-label" for="saveFormat">Save as</label>
                <select id="saveFormat"
                        @bind="saveFormatIndex"
                        @bind:after="OnExportOptionsChanged"
                        disabled="@Workspace.IsBusy">
                    @foreach (var format in Workspace.SaveFormats)
                    {
                        <option value="@format.Index">@format.DisplayName</option>
                    }
                </select>
            </div>

            <div class="option-cell option-span">
                <label class="option-label" for="nameMode">Chapter name</label>
                <select id="nameMode"
                        @bind="chapterNameModeIndex"
                        @bind:after="OnProjectionOptionsChanged"
                        disabled="@Workspace.IsBusy">
                    @for (var i = 0; i < Workspace.ChapterNameModes.Count; i++)
                    {
                        <option value="@i">@Workspace.ChapterNameModes[i]</option>
                    }
                </select>
            </div>

            <div class="option-cell">
                <label class="option-label" for="xmlLang">XML lang</label>
                <select id="xmlLang"
                        @bind="xmlLanguage"
                        @bind:after="OnExportOptionsChanged"
                        disabled="@(Workspace.IsBusy || !Workspace.IsXmlLanguageEnabled)">
                    @foreach (var language in Workspace.XmlLanguages)
                    {
                        <option value="@language">@language</option>
                    }
                </select>
            </div>

            <div class="option-cell">
                <label class="option-label" for="orderShift">Order +</label>
                <input id="orderShift"
                       type="number"
                       min="-1000"
                       max="1000"
                       step="1"
                       @bind="orderShift"
                       @bind:after="OnProjectionOptionsChanged"
                       disabled="@Workspace.IsBusy" />
            </div>

            <div class="option-cell option-expression">
                <label class="option-label">Expression</label>
                <label class="check">
                    <input type="checkbox"
                           checked="@applyExpression"
                           disabled="@(Workspace.IsBusy || Workspace.IsChapterGridEmpty)"
                           @onchange="OnApplyExpressionChanged" />
                    Use
                </label>
                <input class="expression-input"
                       value="@expression"
                       disabled="@(Workspace.IsBusy || !applyExpression || Workspace.IsChapterGridEmpty)"
                       spellcheck="false"
                       title="Lua expression over chapter time, e.g. t + 1 or t * 25 / 24"
                       @oninput="OnExpressionInput"
                       @onchange="OnExpressionCommit" />
            </div>
        </div>
    </div>

    <!-- Status / progress strip -->
    <footer class="status-bar">
        <span class="status-text" title="@Workspace.StatusText">@Workspace.StatusText</span>
        <progress class="status-progress"
                  max="1"
                  value="@(Workspace.Progress > 0 ? Workspace.Progress : 0)"
                  style="@(Workspace.IsBusy || Workspace.Progress > 0 ? null : "visibility:hidden")"></progress>
    </footer>
</div>

@code {
    private int saveFormatIndex;
    private int chapterNameModeIndex;
    private int orderShift;
    private int selectedFrameRateIndex;
    private string xmlLanguage = "eng";
    private bool applyExpression;
    private string expression = "t";
    private bool roundFrames = true;

    protected override void OnInitialized()
    {
        Workspace.Changed += OnWorkspaceChanged;
        PullOptionsFromWorkspace();
    }

    public void Dispose() => Workspace.Changed -= OnWorkspaceChanged;

    private void OnWorkspaceChanged() => InvokeAsync(() =>
    {
        PullOptionsFromWorkspace();
        StateHasChanged();
    });

    private void PullOptionsFromWorkspace()
    {
        saveFormatIndex = Workspace.SaveFormatIndex;
        chapterNameModeIndex = Workspace.ChapterNameModeIndex;
        orderShift = Workspace.OrderShift;
        xmlLanguage = Workspace.XmlLanguage;
        applyExpression = Workspace.ApplyExpression;
        expression = Workspace.Expression;
        roundFrames = Workspace.RoundFrames;
        selectedFrameRateIndex = Workspace.SelectedFrameRateIndex;
    }

    private void PushExportOptions()
    {
        Workspace.SaveFormatIndex = saveFormatIndex;
        Workspace.XmlLanguage = xmlLanguage;
    }

    private void PushProjectionOptions()
    {
        Workspace.ChapterNameModeIndex = chapterNameModeIndex;
        Workspace.OrderShift = orderShift;
        Workspace.ApplyExpression = applyExpression;
        Workspace.Expression = expression;
        Workspace.RoundFrames = roundFrames;
    }

    private void OnExportOptionsChanged()
    {
        PushExportOptions();
        // Save format / XML lang do not rewrite the grid; still notify for control enablement.
        StateHasChanged();
    }

    private void OnProjectionOptionsChanged()
    {
        PushProjectionOptions();
        Workspace.ApplyOptionsAndRefresh();
    }

    private void OnRoundFramesChanged(ChangeEventArgs args)
    {
        roundFrames = args.Value is bool b
            ? b
            : string.Equals(args.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        Workspace.RoundFrames = roundFrames;
        Workspace.ApplyOptionsAndRefresh();
    }

    private void OnFrameRateChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var index))
        {
            selectedFrameRateIndex = index;
            Workspace.SelectedFrameRateIndex = index;
        }
    }

    private void OnApplyExpressionChanged(ChangeEventArgs args)
    {
        applyExpression = args.Value is bool b
            ? b
            : string.Equals(args.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        Workspace.ApplyExpression = applyExpression;
        Workspace.Expression = expression;
        Workspace.ApplyOptionsAndRefresh();
    }

    private void OnExpressionInput(ChangeEventArgs args)
    {
        expression = args.Value?.ToString() ?? "t";
        Workspace.Expression = expression;
        if (applyExpression)
        {
            // Live preview while typing when Use is checked.
            Workspace.ApplyOptionsAndRefresh();
        }
    }

    private void OnExpressionCommit(ChangeEventArgs args)
    {
        expression = args.Value?.ToString() ?? "t";
        Workspace.Expression = expression;
        if (applyExpression)
        {
            Workspace.ApplyOptionsAndRefresh();
        }
    }

    private async Task TriggerLoad()
    {
        await Js.InvokeVoidAsync("chapterToolDemo.click", "loadFileInput");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        await LoadFileAsync(file);
    }

    private Task OnDropAsync(DragEventArgs args) => Task.CompletedTask;

    private async Task LoadFileAsync(IBrowserFile file)
    {
        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 64 * 1024 * 1024);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            PushExportOptions();
            PushProjectionOptions();
            await Workspace.LoadAsync(file.Name, memory.ToArray());
            PullOptionsFromWorkspace();
        }
        catch (Exception ex)
        {
            await Js.InvokeVoidAsync("console.error", ex.Message);
        }
    }

    private async Task LoadSampleAsync()
    {
        PushExportOptions();
        PushProjectionOptions();
        await Workspace.LoadSampleAsync();
        PullOptionsFromWorkspace();
    }

    private async Task SaveAsync()
    {
        PushExportOptions();
        PushProjectionOptions();
        var result = Workspace.Save();
        if (result.Success && result.Content is not null && result.FileName is not null)
        {
            await Js.InvokeVoidAsync("chapterToolDemo.downloadText", result.FileName, result.Content);
        }
    }

    private void OnClipChanged(ChangeEventArgs args)
    {
        Workspace.SelectClip(args.Value?.ToString());
    }

    private void OnTimeChanged(int index, ChangeEventArgs args) =>
        Workspace.UpdateRow(index, args.Value?.ToString(), null);

    private void OnNameChanged(int index, ChangeEventArgs args) =>
        Workspace.UpdateRow(index, null, args.Value?.ToString());
}
